{
  "name": "oss-signal",
  "version": "0.10.0",
  "description": "Maintainer-readiness CLI and GitHub Action with baseline regression gates, OSS triage, CI evidence, SARIF, inventory reports, and adoption packs.",
  "type": "module",
  "bin": {
    "oss-signal": "src/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SalmonPlays/oss-signal.git"
  },
  "bugs": {
    "url": "https://github.com/SalmonPlays/oss-signal/issues"
  },
  "homepage": "https://salmonplays.github.io/oss-signal/",
  "files": [
    "src",
    "scripts",
    "docs/*.css",
    "docs/*.html",
    "docs/*.js",
    "docs/*.md",
    "docs/assets/*.svg",
    "docs/examples",
    "docs/release-manifest.json",
    "docs/release-notes",
    "docs/schema",
    "action.yml",
    "README.md",
    "REVIEWER_PACKET.md",
    "CITATION.cff",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test",
    "lint": "node --check src/*.js test/*.test.js scripts/*.js",
    "audit:self": "node src/cli.js . --format markdown --output docs/self-audit.md",
    "audit:github": "node src/cli.js SalmonPlays/oss-signal --format markdown --output docs/examples/github-url-report.md",
    "audit:check": "node src/cli.js . --format json --fail-under 100 > /dev/null",
    "evidence:verify": "node scripts/verify-evidence.js",
    "evidence:verify:full": "node scripts/verify-evidence.js --require-full",
    "review:ready": "node scripts/verify-reviewer-ready.js",
    "review:ready:full": "node scripts/verify-reviewer-ready.js --require-evidence",
    "package:check": "node scripts/verify-package.js",
    "check": "npm run lint && npm test && npm run audit:check && npm run review:ready",
    "prepublishOnly": "npm run check && npm run package:check"
  },
  "keywords": [
    "open-source",
    "maintainer",
    "maintainer-tools",
    "audit",
    "repository",
    "repository-health",
    "regression-testing",
    "github-action",
    "sarif",
    "cli"
  ],
  "author": "SalmonPlays",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
