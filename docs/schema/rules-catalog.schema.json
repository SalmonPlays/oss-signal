{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://salmonplays.github.io/oss-signal/schema/rules-catalog.schema.json",
  "title": "oss-signal rule catalog JSON",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tool",
    "version",
    "totalRules",
    "totalWeight",
    "scoring",
    "categories"
  ],
  "properties": {
    "tool": {
      "const": "oss-signal"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$"
    },
    "totalRules": {
      "type": "integer",
      "minimum": 0
    },
    "totalWeight": {
      "type": "integer",
      "minimum": 0
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "grades"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "grades": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["grade", "range"],
            "properties": {
              "grade": {
                "type": "string",
                "enum": ["A", "B", "C", "D", "F"]
              },
              "range": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/category"
      }
    }
  },
  "$defs": {
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "rules"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rule"
          }
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "weight", "signals", "why", "fix"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "weight": {
          "type": "integer",
          "minimum": 0
        },
        "signals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "why": {
          "type": "string",
          "minLength": 1
        },
        "fix": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
